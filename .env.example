# Copy to .env and adjust before running docker compose up.

# --- Database -----------------------------------------------------------------
DB_NAME=printerupkeep
DB_USER=printerupkeep
# REQUIRED: choose a strong password
DB_PASSWORD=

# --- API ------------------------------------------------------------------------
# REQUIRED: long random string used to sign JWTs (e.g. `openssl rand -hex 32`)
JWT_SECRET=
JWT_TTL=12h

# --- Initial admin account (created only on first boot, when no users exist) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=System Administrator

# --- Web -------------------------------------------------------------------------
# Host port the app is served on for a local/direct `docker compose up`
# (http://<server>:WEB_PORT). On a managed host the platform proxy handles this.
WEB_PORT=8000

# Pre-built web image pulled on managed hosts (built by GitHub Actions and
# published to GHCR). Override to pin a specific tag or digest, e.g.
#   WEB_IMAGE=ghcr.io/laurencepeter/printerupkeep-web:sha-<commit>
# Local `docker compose up --build` ignores this and builds web from ./app.
WEB_IMAGE=ghcr.io/laurencepeter/printerupkeep-web:main
